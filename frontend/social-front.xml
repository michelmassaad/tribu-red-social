.pub-main {
  max-width: 680px;
}

.pub-titulo {
  font-size: 1.3rem;
  font-weight: 800;
  background: linear-gradient(to right, #06b6d4, #6366f1);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
}

/* Selector de imagen en el formulario */
.btn-imagen-label {
  display: inline-flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.6rem 1.2rem;   /* ← antes: 0.4rem 0.9rem */
  border: 1px dashed var(--app-border);
  border-radius: 8px;
  color: var(--app-text-muted);
  font-size: 0.95rem;        /* ← antes: 0.85rem */
  cursor: pointer;
  transition: all 0.2s;
}

.btn-imagen-label:hover {
  border-color: var(--app-cyan);
  color: var(--app-cyan);
}

/* Botones de ordenamiento */
.btn-group-orden {
  display: flex;
  background: rgba(255, 255, 255, 0.04);
  border: 1px solid var(--app-border);
  border-radius: 10px;
  padding: 3px;
  gap: 3px;
}

.btn-orden {
  background: transparent;
  border: none;
  color: var(--app-text-muted);
  border-radius: 7px;
  padding: 0.4rem 0.9rem;
  font-size: 0.82rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-orden.activo {
  background: var(--app-primary);
  color: white;
}

/* Botón cargar más */
.btn-cargar-mas {
  background: transparent;
  border: 1px solid var(--app-border);
  color: var(--app-text-muted);
  border-radius: 20px;
  padding: 0.5rem 2rem;
  font-size: 0.9rem;
  cursor: pointer;
  transition: all 0.2s;
}

.btn-cargar-mas:hover {
  border-color: var(--app-cyan);
  color: var(--app-cyan);
}

/* ── Modal de confirmación ───────────────────────────────────────────────── */

/* Fondo oscuro detrás del modal — clic encima lo cierra */
.modal-backdrop-ui {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.7);
  backdrop-filter: blur(4px);
  z-index: 1040;
  animation: fadeIn 0.15s ease;
}

/* Contenedor centrado del modal */
.modal-ui {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  z-index: 1050;
  width: 100%;
  max-width: 400px;
  padding: 1rem;
  animation: slideUp 0.2s ease;
}

/* Caja interior del modal */
.modal-ui-content {
  background: rgba(13, 18, 30, 0.97);
  border: 1px solid var(--app-border);
  border-radius: var(--app-radius);
  box-shadow: 0 25px 60px rgba(0, 0, 0, 0.6);
}

/* Botón cancelar */
.btn-modal-cancelar {
  background: transparent;
  border: 1px solid var(--app-border);
  color: var(--app-text-muted);
  border-radius: var(--app-radius-sm);
  padding: 0.55rem 1.5rem;
  font-weight: 600;
  transition: all 0.2s;
}

.btn-modal-cancelar:hover:not(:disabled) {
  border-color: var(--app-text-muted);
  color: var(--app-text);
}

/* Botón confirmar eliminar */
.btn-modal-confirmar {
  background: #f43f5e;
  border: none;
  color: white;
  border-radius: var(--app-radius-sm);
  padding: 0.55rem 1.5rem;
  font-weight: 600;
  transition: all 0.2s;
}

.btn-modal-confirmar:hover:not(:disabled) {
  box-shadow: 0 0 20px rgba(244, 63, 94, 0.4);
  filter: brightness(1.1);
}

.btn-modal-confirmar:disabled,
.btn-modal-cancelar:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

/* Animaciones */
@keyframes fadeIn {
  from { opacity: 0; }
  to   { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translate(-50%, -44%); opacity: 0; }
  to   { transform: translate(-50%, -50%); opacity: 1; }
}
