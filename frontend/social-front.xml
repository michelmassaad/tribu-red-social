      <i class="bi bi-arrow-left me-2"></i>Volver al feed
    </button>

    <!-- ═══ PUBLICACIÓN COMPLETA ═════════════════════════════════ -->
    <div class="card-ui p-4 mb-4">

      <div class="d-flex align-items-center gap-3 mb-3">
        <img
          [src]="publicacion()!.autor.fotoPerfil ||
            'https://ui-avatars.com/api/?name=' + publicacion()!.autor.nombre +
            '&background=6366f1&color=fff&size=48'"
          class="pub-avatar" [alt]="publicacion()!.autor.nombreUsuario"/>
        <div>
          <p class="fw-bold mb-0">
            {{ publicacion()!.autor.nombre }} {{ publicacion()!.autor.apellido }}
          </p>
          <p class="text-muted small mb-0">
            &#64;{{ publicacion()!.autor.nombreUsuario }} ·
            {{ publicacion()!.createdAt | date:'dd/MM/yyyy HH:mm' }}
          </p>
        </div>
      </div>

      <h3 class="fw-bold mb-2">{{ publicacion()!.titulo }}</h3>
      <p class="mb-3" style="color: rgba(248,250,252,0.8);">{{ publicacion()!.descripcion }}</p>

      @if (publicacion()!.imagenUrl) {
        <img [src]="publicacion()!.imagenUrl" [alt]="publicacion()!.titulo"
             class="pub-imagen mb-3" loading="lazy"/>
      }

      <div class="d-flex gap-3 align-items-center">
        <button class="btn-like" [class.activo]="yaLeDiLike()" (click)="toggleLike()">
          <i class="bi" [class.bi-heart-fill]="yaLeDiLike()" [class.bi-heart]="!yaLeDiLike()"></i>
          {{ publicacion()!.likes.length }}
        </button>
        <span class="text-muted small">
          <i class="bi bi-chat me-1"></i>{{ totalComentarios() }} comentarios
        </span>
      </div>
    </div>

    <!-- ═══ SECCIÓN DE COMENTARIOS ═══════════════════════════════ -->
    <div class="card-ui p-4">

      <h6 class="fw-bold mb-4">
        <i class="bi bi-chat-square me-2"></i>Comentarios ({{ totalComentarios() }})
      </h6>

      <!-- Formulario para escribir un comentario -->
      <div class="d-flex gap-3 mb-4 align-items-start">
        <img
          [src]="auth.user()?.fotoPerfil || 'https://ui-avatars.com/api/?name=' + auth.nombreCompleto() + '&background=6366f1&color=fff&size=36'"
          class="comentario-avatar" alt="Mi avatar"/>
        <div class="flex-grow-1">
          <textarea
            class="form-control form-control-ui mb-2"
            rows="2" placeholder="Escribí un comentario..."
            style="resize: none;"
            [value]="nuevoComentario()"
            (input)="nuevoComentario.set($any($event.target).value)"
            (keydown.enter)="$event.preventDefault(); enviarComentario()">
          </textarea>
          <button class="btn btn-ui-primary btn-sm"
                  [disabled]="!nuevoComentario().trim() || enviandoComentario()"
                  (click)="enviarComentario()">
            @if (enviandoComentario()) {
              <span class="spinner-border spinner-border-sm me-1"></span> Enviando...
            } @else {
              <i class="bi bi-send-fill me-1"></i> Comentar
            }
          </button>
        </div>
      </div>

      <!-- Lista de comentarios -->
      @if (cargandoComentarios()) {
        <div class="text-center py-3">
          <div class="spinner-border spinner-border-sm text-primary"></div>
        </div>
      } @else if (comentarios().length === 0) {
        <p class="text-muted text-center small py-3">
          <i class="bi bi-chat-square me-1"></i>
          Todavía no hay comentarios. ¡Sé el primero!
        </p>
      } @else {
        <div class="comentarios-lista">
          @for (c of comentarios(); track c._id) {
            <div class="comentario-item">
              <img
                [src]="c.autor.fotoPerfil ||
                  'https://ui-avatars.com/api/?name=' + c.autor.nombre +
                  '&background=6366f1&color=fff&size=36'"
                class="comentario-avatar" [alt]="c.autor.nombreUsuario"/>

              <div class="comentario-cuerpo flex-grow-1">

                <!-- Cabecera del comentario -->
                <div class="d-flex align-items-center gap-2 mb-1 flex-wrap">
                  <span class="comentario-autor">
                    {{ c.autor.nombre }} {{ c.autor.apellido }}
                  </span>
                  <span class="comentario-fecha">
                    {{ c.createdAt | date:'dd/MM/yy HH:mm' }}
                  </span>
                  <!-- Badge "editado" — aparece cuando modificado:true -->
                  @if (c.modificado) {
                    <span class="badge-editado">editado</span>
                  }
                  <!-- Botón editar — solo visible para el autor del comentario -->
                  @if (puedoEditarComentario(c.autor._id) && comentarioEditandoId() !== c._id) {
                    <button class="btn-editar-comentario ms-auto" (click)="iniciarEdicion(c)">
                      <i class="bi bi-pencil"></i>
                    </button>
                  }
                </div>

                <!-- Modo lectura o modo edición -->
                @if (comentarioEditandoId() === c._id) {
                  <!-- Modo edición: textarea con botones guardar/cancelar -->
                  <textarea
                    class="form-control form-control-ui mb-2"
                    rows="2" style="resize: none;"
                    [value]="textoEdicion()"
                    (input)="textoEdicion.set($any($event.target).value)">
                  </textarea>
                  <div class="d-flex gap-2">
                    <button class="btn btn-ui-primary btn-sm"
                            [disabled]="!textoEdicion().trim() || guardandoEdicion()"
                            (click)="guardarEdicion(c._id)">
                      @if (guardandoEdicion()) {
                        <span class="spinner-border spinner-border-sm me-1"></span>
                      }
                      Guardar
                    </button>
                    <button class="btn btn-modal-cancelar btn-sm" (click)="cancelarEdicion()">
                      Cancelar
                    </button>
                  </div>
                } @else {
                  <!-- Modo lectura: solo muestra el texto -->
                  <p class="comentario-texto mb-0">{{ c.contenido }}</p>
                }

              </div>
            </div>
          }
        </div>

        <!-- Botón cargar más — solo aparece si hay más comentarios -->
        @if (hayMasComentarios()) {
          <div class="text-center mt-4">
            <button class="btn-cargar-mas" (click)="cargarMasComentarios()"
                    [disabled]="cargandoMasComentarios()">
              @if (cargandoMasComentarios()) {
                <span class="spinner-border spinner-border-sm me-2"></span> Cargando...
              } @else {
                Cargar más comentarios
              }
            </button>
          </div>
        }
      }

    </div>
  }
</div>
</file>

