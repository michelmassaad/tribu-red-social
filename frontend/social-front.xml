      <h5 class="fw-bold mb-0">
        <i class="bi bi-layout-text-sidebar me-2 text-muted"></i>Mis últimas publicaciones
      </h5>
      <small class="text-muted">{{ publicaciones().length }} publicaciones</small>
    </div>

    @if (publicaciones().length === 0) {
      <div class="card-ui text-center py-5">
        <i class="bi bi-pencil-square fs-1 text-muted d-block mb-2"></i>
        <p class="text-muted mb-0 small">Todavía no hiciste ninguna publicación.</p>
      </div>
    } @else {
      @for (pub of publicaciones(); track pub._id) {
        <app-tarjeta-publicacion
          [publicacion]="pub"
          (onToggleLike)="toggleLike($event)"
          (onEliminar)="eliminar($event)">
        </app-tarjeta-publicacion>
      }
    }

  }
</div>
