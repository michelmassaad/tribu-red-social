            <div>
              <small class="text-muted d-block label-dato">Correo electrónico</small>
              <span class="text-white small">{{ usuario()?.correo }}</span>
            </div>
          </div>
        </div>

        <div class="col-12 col-sm-6">
          <div class="dato-item">
            <i class="bi bi-person" style="color: var(--app-cyan);"></i>
            <div>
              <small class="text-muted d-block label-dato">Nombre de usuario</small>
              <span class="text-white small">&#64;{{ usuario()?.nombreUsuario }}</span>
            </div>
          </div>
        </div>

        <div class="col-12 col-sm-6">
          <div class="dato-item">
            <i class="bi bi-calendar3" style="color: var(--app-cyan);"></i>
            <div>
              <small class="text-muted d-block label-dato">Fecha de nacimiento</small>
              <span class="text-white small">{{ usuario()?.fechaNacimiento | date:'dd/MM/yyyy' }}</span>
            </div>
          </div>
        </div>

        <div class="col-12 col-sm-6">
          <div class="dato-item">
            <i class="bi bi-clock-history" style="color: var(--app-cyan);"></i>
            <div>
              <small class="text-muted d-block label-dato">Miembro desde</small>
              <span class="text-white small">{{ usuario()?.createdAt | date:'MMMM yyyy' }}</span>
            </div>
          </div>
        </div>

      </div>
