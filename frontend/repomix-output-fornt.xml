/* 🌌 RED SOCIAL — COSMIC MINIMALIST DESIGN SYSTEM 2026 */
@import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap');

:root {
  --app-bg: radial-gradient(circle at 50% 0%, #1a153a 0%, #070913 50%, #030408 100%);
  --app-surface: rgba(13, 18, 30, 0.7);
  --app-border: rgba(255, 255, 255, 0.08);
  --app-border-focus: rgba(99, 102, 241, 0.4);
  
  --app-primary: #6366f1;         /* 🔥 CORREGIDO: Token base individual para controles interactivos */
  --app-gradient-primary: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
  --app-gradient-cyan: linear-gradient(135deg, #06b6d4 0%, #3b82f6 100%);
  --app-cyan: #06b6d4;
  --app-text: #f8fafc;
  --app-text-muted: #64748b;
  --app-danger: #f43f5e;
  --app-success: #10b981;
  
  --app-radius: 16px;
  --app-radius-sm: 8px;
}

body {
  font-family: 'Plus Jakarta Sans', sans-serif;
  background: var(--app-bg) !important;
  background-attachment: fixed !important;
  color: var(--app-text);
  min-height: 100vh;
  margin: 0;
  -webkit-font-smoothing: antialiased;
}

/* 💎 CONTENEDORES DE CRISTAL UNIFICADOS */
.card-ui {
  background: var(--app-surface);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--app-border);
  border-radius: var(--app-radius);
  box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
  transition: border-color 0.3s ease, box-shadow 0.3s ease;
}

.card-ui:hover {
  border-color: rgba(99, 102, 241, 0.2);
  box-shadow: 0 20px 50px rgba(99, 102, 241, 0.05);
}

/* 📝 FORMULARIOS PREMIUM */
.form-control-ui {
  background: rgba(0, 0, 0, 0.4) !important;
  border: 1px solid var(--app-border) !important;
  color: var(--app-text) !important;
  border-radius: var(--app-radius-sm) !important;
  padding: 0.75rem 1.2rem;
  font-size: 0.95rem;
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
}

.form-control-ui:focus {
  border-color: var(--app-cyan) !important;
  background: rgba(0, 0, 0, 0.55) !important;
  box-shadow: 0 0 20px rgba(6, 182, 212, 0.15) !important;
}

.form-control-ui.is-invalid {
  border-color: var(--app-danger) !important;
  box-shadow: 0 0 15px rgba(244, 63, 94, 0.15) !important;
}

/* 🚀 INTERFACES COMPARTIDAS (BOTONES Y ENLACES) */
.btn-ui-primary {
  background: var(--app-gradient-primary) !important;
  color: #ffffff !important;
  border: none !important;
  border-radius: var(--app-radius-sm) !important;
  padding: 0.75rem 1.5rem;
  font-weight: 600;
  transition: all 0.2s ease;
  box-shadow: 0 4px 15px rgba(99, 102, 241, 0.25);
}

.btn-ui-primary:hover:not(:disabled) {
  box-shadow: 0 6px 25px rgba(99, 102, 241, 0.5);
  transform: translateY(-1px);
  filter: brightness(1.1);
}

.btn-ui-primary:disabled {
  opacity: 0.4;
  cursor: not-allowed;
  transform: none !important;
  box-shadow: none !important;
}

.btn-ui-input-group {
  border: 1px solid var(--app-border) !important;
  border-left: none !important;
  background: rgba(0, 0, 0, 0.4) !important;
  border-top-right-radius: var(--app-radius-sm) !important;
  border-bottom-right-radius: var(--app-radius-sm) !important;
  color: var(--app-text-muted) !important;
  padding: 0 1.2rem !important;
}

/* ⚡ CUSTOMIZACIÓN DE CONTROLES NATIVOS (RADIO/CHECK/FILE) */
.radio-ui:checked {
  background-color: var(--app-primary) !important;
  border-color: var(--app-primary) !important;
  box-shadow: 0 0 12px rgba(99, 102, 241, 0.6) !important;
}

.custom-file-input-ui::-webkit-file-upload-button {
  background-color: rgba(255, 255, 255, 0.08);
  color: var(--app-text);
  border: 1px solid var(--app-border);
  border-radius: 4px;
  padding: 0.2rem 0.6rem;
  margin-right: 8px;
  cursor: pointer;
  transition: background 0.2s;
}

.custom-file-input-ui::-webkit-file-upload-button:hover {
  background-color: rgba(255, 255, 255, 0.15);
}

/* ALERTAS CON TRANSPARENCIA */
.alert-ui-danger {
  background: rgba(244, 63, 94, 0.1) !important;
  border: 1px solid rgba(244, 63, 94, 0.2) !important;
  color: #fda4af !important;
  border-radius: var(--app-radius-sm);
}

.alert-ui-success {
  background: rgba(16, 185, 129, 0.1) !important;
  border: 1px solid rgba(16, 185, 129, 0.2) !important;
  color: #6ee7b7 !important;
  border-radius: var(--app-radius-sm);
}
